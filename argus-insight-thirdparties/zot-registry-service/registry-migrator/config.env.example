# =============================================================
# Registry Migrator Configuration
# =============================================================
# Copy this file to config.env and edit the values.

# ---------------------------------------------------------
# Source registry (Zot)
# ---------------------------------------------------------
SRC_REGISTRY="zot.example.com:5000"
SRC_SCHEME="https"
SRC_USERNAME="admin"
SRC_PASSWORD="changeme"
# Set to "false" if using self-signed certificates
SRC_TLS_VERIFY="true"

# ---------------------------------------------------------
# Destination registry (Harbor, Zot, Docker Hub, etc.)
# ---------------------------------------------------------
DST_REGISTRY="harbor.example.com"
DST_SCHEME="https"
DST_USERNAME="admin"
DST_PASSWORD="changeme"
# Set to "false" if using self-signed certificates
DST_TLS_VERIFY="true"

# Optional: prefix all repositories in the destination
# e.g. DST_PROJECT_PREFIX="library" -> image "nginx" becomes "library/nginx"
DST_PROJECT_PREFIX=""
