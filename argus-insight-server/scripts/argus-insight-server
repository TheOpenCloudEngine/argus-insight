#!/usr/bin/env python3
"""Argus Insight Server entry point."""

import os
import sys

# Add the package root to sys.path when running from /opt/argus-insight-server
lib_dir = "/opt/argus-insight-server"
if os.path.isdir(lib_dir) and lib_dir not in sys.path:
    sys.path.insert(0, lib_dir)

import uvicorn
from app.core.config import settings


def main():
    uvicorn.run(
        "app.main:app",
        host=settings.host,
        port=settings.port,
        log_level=settings.log_level.lower(),
    )


if __name__ == "__main__":
    main()
