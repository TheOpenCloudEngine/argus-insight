#!/usr/bin/make -f

%:
	dh $@ --with python3

override_dh_auto_install:
	# Application
	mkdir -p debian/argus-agent/usr/lib/argus-agent
	cp -r app debian/argus-agent/usr/lib/argus-agent/

	# Install Python dependencies
	pip3 install --root=debian/argus-agent --prefix=/usr --no-deps .

	# Entry point
	mkdir -p debian/argus-agent/usr/bin
	install -m 755 scripts/argus-agent debian/argus-agent/usr/bin/argus-agent

	# Config
	mkdir -p debian/argus-agent/etc/argus
	install -m 640 packaging/config/agent.env.example debian/argus-agent/etc/argus/agent.env

	# Directories
	mkdir -p debian/argus-agent/var/log/argus
	mkdir -p debian/argus-agent/var/lib/argus
