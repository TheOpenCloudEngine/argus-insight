# Argus Server Agent Configuration
# Copy this file to /etc/argus/agent.env and modify as needed.

# Server settings
# ARGUS_HOST=0.0.0.0
# ARGUS_PORT=8600
# ARGUS_DEBUG=false

# Logging
# ARGUS_LOG_LEVEL=INFO

# Command execution
# ARGUS_COMMAND_TIMEOUT=300
# ARGUS_COMMAND_MAX_OUTPUT=1048576

# Monitor
# ARGUS_MONITOR_INTERVAL=5

# Terminal
# ARGUS_TERMINAL_SHELL=/bin/bash
# ARGUS_TERMINAL_MAX_SESSIONS=10
