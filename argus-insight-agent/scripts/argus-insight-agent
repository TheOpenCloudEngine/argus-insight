#!/usr/bin/env python3
"""Argus Insight Agent entry point."""

import os
import sys

# Add the package root to sys.path when running from /opt/argus-insight-agent
lib_dir = "/opt/argus-insight-agent"
if os.path.isdir(lib_dir) and lib_dir not in sys.path:
    sys.path.insert(0, lib_dir)

from app.main import run

if __name__ == "__main__":
    run()
