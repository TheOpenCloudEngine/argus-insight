# Argus Insight Server port for API proxy (default: 4500)
# Middleware automatically uses the same hostname as the incoming request
API_PORT=4500

# Allowed dev origins (comma-separated, for cross-origin dev access warning)
# Example: ALLOWED_DEV_ORIGINS=http://10.0.1.50:3000,http://192.168.1.100:3000
ALLOWED_DEV_ORIGINS=http://10.0.1.50:3000,http://10.0.1.50:4500,http://localhost:3000,http://localhost:4500
