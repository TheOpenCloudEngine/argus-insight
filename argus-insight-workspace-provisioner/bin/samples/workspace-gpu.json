{
  "name": "gpu-training",
  "display_name": "GPU Training Workspace",
  "description": "High-resource workspace for GPU-based ML training",
  "domain": "dev.net",
  "k8s_cluster": "gpu-cluster",
  "k8s_namespace": "argus-ws-gpu-training",
  "admin_user_id": 1,
  "provisioning_config": {
    "minio": {
      "storage_size": "500Gi",
      "resources": {
        "cpu_request": "1",
        "cpu_limit": "4",
        "memory_request": "2Gi",
        "memory_limit": "8Gi"
      }
    },
    "airflow": {
      "dags_storage_size": "50Gi",
      "logs_storage_size": "100Gi",
      "db_storage_size": "20Gi",
      "webserver_resources": {
        "cpu_request": "1",
        "cpu_limit": "4",
        "memory_request": "2Gi",
        "memory_limit": "8Gi"
      },
      "scheduler_resources": {
        "cpu_request": "1",
        "cpu_limit": "8",
        "memory_request": "4Gi",
        "memory_limit": "16Gi"
      }
    },
    "mlflow": {
      "db_storage_size": "50Gi",
      "resources": {
        "cpu_request": "1",
        "cpu_limit": "4",
        "memory_request": "2Gi",
        "memory_limit": "8Gi"
      }
    },
    "kserve": {
      "default_runtime": "kserve-triton",
      "resources": {
        "cpu_request": "1",
        "cpu_limit": "4",
        "memory_request": "2Gi",
        "memory_limit": "8Gi"
      }
    }
  }
}
